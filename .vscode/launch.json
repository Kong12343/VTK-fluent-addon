{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Current File (Release)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/build-release/${fileDirnameBasename}.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\tools\\msys64\\mingw64\\bin\\gdb.exe",
      "miDebuggerArgs": "-q",
      "preLaunchTask": "CMake Clang Build Current File (Release)",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Launch Current File (Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/build-debug/${fileDirnameBasename}.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\tools\\msys64\\mingw64\\bin\\gdb.exe",
      "miDebuggerArgs": "-q",
      "preLaunchTask": "CMake Clang Build Current File (Debug)",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
